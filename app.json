{
  "expo": {
    "name": "Daylog",
    "slug": "daylog-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#ECEAE3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.daylog.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ECEAE3"
      },
      "package": "com.daylog.mobile"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#7C5CFC",
          "iosDisplayInForeground": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8f667733-713a-4cd9-89f2-7b41dfcfc8e5"
      }
    }
  }
}
